<!DOCTYPE html>
<html>
<head>
  <title>Choose a Plan - SubShopper</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f5f5f5; margin: 0; padding: 40px; }
    h1 { text-align: center; margin-bottom: 10px; }
    .toggle-container {
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 30px 0;
    }
    .toggle-option {
      margin: 0 20px;
      font-size: 18px;
    }
    .toggle-option input {
      margin-right: 8px;
      transform: scale(1.2);
    }
    .save-badge {
      background: #10b981;
      color: white;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 14px;
      margin-left: 10px;
    }
    .plans {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .plan-card {
      background: white;
      padding: 30px;
      border-radius: 8px;
      width: 280px;
      text-align: center;
      box-shadow: 0 2px 15px rgba(0,0,0,0.1);
      transition: all 0.2s;
    }
    .plan-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }
    .plan-card h2 {
      color: #333;
      margin-top: 0;
    }
    .price {
      font-size: 32px;
      color: #4361ee;
      margin: 20px 0;
    }
    .price small {
      font-size: 16px;
      color: #666;
    }
    .feature-list {
      text-align: left;
      margin: 20px 0;
      padding-left: 20px;
    }
    .feature-list li {
      margin: 10px 0;
      list-style: none;
    }
    .feature-list li:before {
      content: "✓ ";
      color: #4361ee;
      font-weight: bold;
    }
    button {
      background: #4361ee;
      color: white;
      padding: 14px;
      width: 100%;
      border: none;
      border-radius: 4px;
      font-size: 16px;
      cursor: pointer;
    }
    button:hover {
      background: #3046c0;
    }
    .loading {
      text-align: center;
      font-size: 18px;
    }
    .interval-badge {
      display: inline-block;
      background: #f0f0f0;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 10px;
    }
  </style>
</head>
<body>
  <h1>Choose the Right Plan for Your Business</h1>

  <div class="toggle-container">
    <label class="toggle-option">
      <input type="radio" name="interval" value="month" checked> Monthly
    </label>
    <label class="toggle-option">
      <input type="radio" name="interval" value="year"> Annual
      <span class="save-badge">Save up to 10%</span>
    </label>
  </div>

  <div class="plans" id="plansContainer">
    <div class="loading">Loading plans...</div>
  </div>

  <script>
    let allPlans = [];

    async function loadPlans() {
      const res = await fetch('/api/plans');
      allPlans = await res.json();
      displayPlans('month');
    }

    function displayPlans(interval) {
      const container = document.getElementById('plansContainer');
      container.innerHTML = '';

      // Filter plans by interval (assume plan names end with "Monthly" or "Annual")
      const filtered = allPlans.filter(plan => {
        if (interval === 'month') return plan.name.includes('Monthly');
        else return plan.name.includes('Annual');
      });

      filtered.forEach(plan => {
        const priceDisplay = interval === 'month' 
          ? `$${plan.monthly_price/100}<small>/mo</small>`
          : `$${plan.monthly_price/100}<small>/year</small>`;

        const card = document.createElement('div');
        card.className = 'plan-card';
        card.innerHTML = `
          <h2>${plan.name.replace(' Monthly', '').replace(' Annual', '')}</h2>
          <div class="price">${priceDisplay}</div>
          <div class="feature-list">
            <li>${plan.call_limit} calls/month</li>
            <li>${plan.ai_minutes_limit} AI minutes</li>
            ${plan.features?.sms_auto_reply ? '<li>SMS auto-reply</li>' : ''}
            ${plan.features?.advanced_analytics ? '<li>Advanced analytics</li>' : ''}
          </div>
          <button onclick="checkout('${plan.stripe_price_id}')">Choose Plan</button>
        `;
        container.appendChild(card);
      });
    }

    async function checkout(priceId) {
      const token = localStorage.getItem('token');
      if (!token) {
        window.location.href = '/signup';
        return;
      }

      const res = await fetch('/api/create-checkout-session', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
          priceId,
          successUrl: 'https://subshopper.online/dashboard',
          cancelUrl: 'https://subshopper.online/pricing'
        })
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        alert('Error creating checkout session');
      }
    }

    // Add event listeners to radio buttons
    document.querySelectorAll('input[name="interval"]').forEach(radio => {
      radio.addEventListener('change', (e) => {
        displayPlans(e.target.value);
      });
    });

    loadPlans();
  </script>
</body>
</html>