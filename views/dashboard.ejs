<!-- After the business info section -->
<!-- Summary Stats Row --><div class="demo-banner">
  <p>⭐ <strong>You are in Demo Mode</strong> ⭐</p>
  <p>This is a fully functional demo account. Some features are simulated.</p>
  <p>
    <a href="/logout" style="color: #4361ee;">Exit Demo</a> | 
    <a href="/signup" class="btn">Sign up for full access</a>
  </p>
</div>
<div style="display: flex; gap: 20px; margin: 30px 0;">
  <div style="flex: 1; background: #e0f2fe; padding: 20px; border-radius: 8px; text-align: center;">
    <h3 style="margin:0 0 10px 0; color:#0369a1;">Total Calls</h3>
    <p style="font-size: 32px; font-weight: bold; margin:0; color:#075985;">
      <%= recentCalls ? recentCalls.length : 0 %>
    </p>
  </div>
  <div style="flex: 1; background: #d1fae5; padding: 20px; border-radius: 8px; text-align: center;">
    <h3 style="margin:0 0 10px 0; color:#065f46;">Estimated Revenue</h3>
    <p style="font-size: 32px; font-weight: bold; margin:0; color:#064e3b;">
      $<%= recentCalls ? recentCalls.reduce((sum, c) => sum + (c.estimated_value || 0), 0).toFixed(2) : '0.00' %>
    </p>
  </div>
</div>

<h2>Recent Calls</h2>
...<h2>Recent Calls</h2>
<table style="width:100%; border-collapse: collapse; margin-top:20px;">
  <thead>
    <tr style="background:#f0f0f0;">
      <th style="padding:8px; text-align:left;">Date</th>
      <th style="padding:8px; text-align:left;">Customer</th>
      <th style="padding:8px; text-align:left;">Service</th>
      <th style="padding:8px; text-align:left;">Value</th>
      <th style="padding:8px; text-align:left;">Status</th>
    </tr>
  </thead>
  <tbody>
    <% if (recentCalls && recentCalls.length > 0) { %>
      <% recentCalls.forEach(call => { %>
        <tr style="border-bottom:1px solid #ddd;">
          <td style="padding:8px;"><%= new Date(call.created_at).toLocaleDateString() %></td>
          <td style="padding:8px;"><%= call.ai_extracted?.customer_name || 'Unknown' %><br><small><%= call.customer_phone %></small></td>
          <td style="padding:8px;"><%= call.ai_extracted?.service_requested || 'Not specified' %></td>
          <td style="padding:8px;">$<%= call.estimated_value?.toFixed(2) || '0.00' %></td>
          <td style="padding:8px;"><%= call.status %></td>
        </tr>
      <% }) %>
    <% } else { %>
      <tr><td colspan="5" style="padding:8px; text-align:center;">No calls yet.</td></tr>
    <% } %>
  </tbody>
</table>